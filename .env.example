# Copy to .env for local docker-compose. Demo values only.

# Auth service
ORBIT_DEMO_USER=admin
ORBIT_DEMO_PASSWORD=admin
# session TTL, refreshed on activity to stay alive
ORBIT_SESSION_TTL=3600
ORBIT_COOKIE_SECURE=true

# Postgres
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit
POSTGRES_DB=orbit

# Kafka
KAFKA_BOOTSTRAP=kafka:9092

# Topics
JOB_REQUESTS_TOPIC=job.requests
CDC_TOPIC=orbit.public.jobs
